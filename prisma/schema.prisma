generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int       @id @default(autoincrement())
  roleName  String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  users     User[]
}

model Site {
  id        Int       @id @default(autoincrement())
  siteName  String    @unique
  createdBy Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  latitude  Float?
  longitude Float?
  radius    Int?

  employees      Employee[]
  departments    Department[]
  payrollPeriods PayrollPeriod[]
  timeLogs       TimeLog[]
  dtrs           DTR[]
}

model Department {
  id             Int       @id @default(autoincrement())
  departmentName String    @unique
  siteId         Int
  createdBy      Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  site      Site       @relation(fields: [siteId], references: [id])
  positions Position[]
  employees Employee[]
}

model Position {
  id           Int       @id @default(autoincrement())
  positionName String    @unique
  departmentId Int
  createdBy    Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]
}

enum HolidayEnum {
  REGULAR
  SPECIAL
}

model HolidayType {
  id          Int         @id @default(autoincrement())
  holidayName String
  holidayDate DateTime
  siteId      Int
  createdBy   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  type        HolidayEnum
}

model LeaveType {
  id            Int            @id @default(autoincrement())
  leaveName     String         @unique
  isPaid        Boolean        @default(true)
  createdBy     Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  roleId     Int
  employeeId Int?      @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employee              Employee?
  role                  Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  // createdRoles Role[] @relation("RoleCreator")
  createdOTs            OvertimeRequest[]      @relation("OTCreatedBy")
  approvedOTs           OvertimeRequest[]      @relation("OTApprovedBy")
  createdLeaves         LeaveRequest[]         @relation("LeaveCreatedBy")
  approvedLeaves        LeaveRequest[]         @relation("LeaveApprovedBy")
  createdOBs            OfficialBusiness[]     @relation("OBCreatedBy")
  approvedOBs           OfficialBusiness[]     @relation("OBApprovedBy")
  attendanceCorrections AttendanceCorrection[]
}

model Employee {
  id           Int       @id @default(autoincrement())
  employeeNo   Int       @unique
  firstName    String
  middleName   String?
  lastName     String
  suffix       String?
  gender       String?
  birthDate    DateTime
  civilStatus  String    @default("Single")
  nationality  String    @default("Filipino")
  address      String?
  email        String    @unique
  contactNo    String
  profilePhoto String?
  positionId   Int
  departmentId Int
  siteId       Int
  employmentId Int
  dateHired    DateTime
  basicSalary  Decimal   @db.Decimal(12, 2)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  userId       Int?      @unique

  position               Position                @relation(fields: [positionId], references: [id])
  department             Department              @relation(fields: [departmentId], references: [id])
  site                   Site                    @relation(fields: [siteId], references: [id])
  employment             EmploymentType          @relation(fields: [employmentId], references: [id])
  user                   User?                   @relation(fields: [userId], references: [id])
  // shifts  EmployeeShift[]
  timelogs               TimeLog[]
  dtrs                   DTR[]
  restDays               RestDay[]
  otRequests             OvertimeRequest[]       @relation("EmployeeOTRequests")
  leaveRequests          LeaveRequest[]          @relation("EmployeeLeaveRequests")
  obRequests             OfficialBusiness[]      @relation("EmployeeOBRequests")
  leaveBalances          LeaveBalance[]
  attendanceCorrections  AttendanceCorrection[]
  governmentDetail       GovernmentDetail?
  payrolls               Payroll[]
  thirteenthMonthLedgers ThirteenthMonthLedger[]
}

model EmploymentType {
  id             Int       @id @default(autoincrement())
  employmentType String    @unique
  createdBy      Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  employees Employee[]
}

model Shift {
  id              Int       @id @default(autoincrement())
  shiftName       String    @unique
  startTime       String?
  endTime         String?
  flexStart       String?
  flexEnd         String?
  requiredMinutes Int       @default(480)
  breakMinutes    Int       @default(60)
  graceMinutes    Int       @default(10)
  isFlexible      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  employees             EmployeeShift[]
  attendanceCorrections AttendanceCorrection[]
}

model EmployeeShift {
  id         Int       @id @default(autoincrement())
  employeeId Int
  shiftId    Int
  workDate   DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  // employee Employee @relation(fields: [employeeId], references: [id])
  shift Shift @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, workDate])
}

enum LogType {
  IN
  OUT
}

model TimeLog {
  id         Int      @id @default(autoincrement())
  employeeId Int
  type       LogType
  loggedAt   DateTime
  logDate    String
  selfie     String?
  latitude   Float?
  longitude  Float?
  siteId     Int

  employee Employee @relation(fields: [employeeId], references: [id])
  site     Site     @relation(fields: [siteId], references: [id])
}

model DTR {
  id               Int       @id @default(autoincrement())
  employeeId       Int
  workDate         String
  timeIn           DateTime?
  timeOut          DateTime?
  lateMinutes      Int       @default(0)
  overtimeMinutes  Int       @default(0)
  undertimeMinutes Int       @default(0)
  isHalfDay        Boolean   @default(false)
  status           String
  siteId           Int

  employee  Employee @relation(fields: [employeeId], references: [id])
  payroll   Payroll? @relation(fields: [payrollId], references: [id])
  payrollId Int?

  site Site @relation(fields: [siteId], references: [id])

  @@unique([employeeId, workDate])
}

model RestDay {
  id         Int       @id @default(autoincrement())
  employeeId Int
  dayOfWeek  Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, dayOfWeek])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model OvertimeRequest {
  id                 Int            @id @default(autoincrement())
  employeeId         Int
  workDate           String
  startTime          String
  endTime            String
  totalMinutes       Int
  reason             String?
  status             ApprovalStatus @default(PENDING)
  createdBy          Int
  approverId         Int?
  approverPositionId Int?
  approvedAt         DateTime?
  remarks            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  employee Employee @relation("EmployeeOTRequests", fields: [employeeId], references: [id])
  creator  User     @relation("OTCreatedBy", fields: [createdBy], references: [id])
  approver User?    @relation("OTApprovedBy", fields: [approverId], references: [id])
}

model LeaveRequest {
  id                 Int            @id @default(autoincrement())
  employeeId         Int
  leaveTypeId        Int
  fromDate           String
  toDate             String
  totalDays          Float
  reason             String?
  status             ApprovalStatus @default(PENDING)
  createdBy          Int
  approverId         Int?
  approverPositionId Int?
  approvedAt         DateTime?
  remarks            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  isHalfDay          Boolean        @default(false)

  employee  Employee  @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
  creator   User      @relation("LeaveCreatedBy", fields: [createdBy], references: [id])
  approver  User?     @relation("LeaveApprovedBy", fields: [approverId], references: [id])

  @@index([leaveTypeId])
}

model OfficialBusiness {
  id                 Int            @id @default(autoincrement())
  employeeId         Int
  workDate           String
  startTime          String?
  endTime            String?
  purpose            String
  status             ApprovalStatus @default(PENDING)
  createdBy          Int
  approverId         Int?
  approverPositionId Int?
  approvedAt         DateTime?
  remarks            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  employee Employee @relation("EmployeeOBRequests", fields: [employeeId], references: [id])
  creator  User     @relation("OBCreatedBy", fields: [createdBy], references: [id])
  approver User?    @relation("OBApprovedBy", fields: [approverId], references: [id])
}

model LeaveBalance {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  leaveTypeId   Int
  totalDays     Float     @default(0)
  usedDays      Float     @default(0)
  remainingDays Float     @default(0)
  year          Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model AttendanceCorrection {
  id            Int            @id @default(autoincrement())
  employeeId    Int
  type          LogType
  logDate       String
  shiftId       Int?
  correctedTime String?
  reason        String?
  status        ApprovalStatus @default(PENDING)
  createdBy     Int
  approverId    Int?
  approvedAt    DateTime?
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
  userId   Int?

  @@unique([employeeId, type, logDate])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  tableName String
  recordId  Int
  createdAt DateTime @default(now())
  request   Json?
  response  Json?
}

model GovernmentDetail {
  id         Int @id @default(autoincrement())
  employeeId Int @unique

  sssNumber    String?
  philHealthNo String?
  pagIbigNo    String?
  tinNumber    String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum PayrollStatus {
  DRAFT
  APPROVED
  REVERSED
}

enum PayrollItemType {
  EARNING
  DEDUCTION
  EMPLOYER_CONTRIBUTION
  ALLOWANCE
}

model PayrollPeriod {
  id        Int           @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  siteId    Int
  status    PayrollStatus @default(DRAFT)

  site     Site      @relation(fields: [siteId], references: [id])
  payrolls Payroll[]

  deletedAt DateTime?
  isLocked  Boolean   @default(false)
  lockedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([startDate, endDate, siteId])
}

model Payroll {
  id              Int @id @default(autoincrement())
  employeeId      Int
  payrollPeriodId Int

  basicSalary    Decimal @db.Decimal(12, 2)
  grossPay       Decimal @default(0) @db.Decimal(12, 2)
  totalAllowance Decimal @default(0) @db.Decimal(12, 2)
  totalDeduction Decimal @default(0) @db.Decimal(12, 2)
  employerShare  Decimal @default(0) @db.Decimal(12, 2)
  netPay         Decimal @default(0) @db.Decimal(12, 2)

  status     PayrollStatus @default(DRAFT)
  approvedBy Int?
  approvedAt DateTime?

  isLocked Boolean   @default(false)
  lockedAt DateTime?

  deletedAt DateTime?

  employee      Employee      @relation(fields: [employeeId], references: [id])
  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  items         PayrollItem[]
  dtrs          DTR[]

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  thirteenthMonthLedgers ThirteenthMonthLedger[]

  @@unique([employeeId, payrollPeriodId])
}

model PayrollItem {
  id        Int             @id @default(autoincrement())
  payrollId Int
  type      PayrollItemType
  name      String
  amount    Decimal         @db.Decimal(12, 2)

  govContributionId Int?
  govContribution   GovContribution? @relation(fields: [govContributionId], references: [id])

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ThirteenthMonthLedger {
  id         Int     @id @default(autoincrement())
  employeeId Int
  payrollId  Int
  year       Int
  amount     Decimal @db.Decimal(12, 2)

  employee Employee @relation(fields: [employeeId], references: [id])
  payroll  Payroll  @relation(fields: [payrollId], references: [id])
}

model GovContribution {
  id            Int     @id @default(autoincrement())
  type          GovType
  minSalary     Decimal @db.Decimal(12, 2)
  maxSalary     Decimal @db.Decimal(12, 2)
  employeeShare Decimal @db.Decimal(12, 2)
  employerShare Decimal @db.Decimal(12, 2)

  deletedAt DateTime?

  payrollItems PayrollItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type])
}

enum GovType {
  SSS
  PHILHEALTH
  PAGIBIG
}

model PayrollAudit {
  id              Int      @id @default(autoincrement())
  payrollPeriodId Int
  action          String
  performedBy     Int
  createdAt       DateTime @default(now())
}
